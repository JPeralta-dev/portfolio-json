---
import { basics } from "@cv"
import { ViewTransitions } from "astro:transitions"

interface Props {
  title: string
}

const { title } = Astro.props

const { image, summary, url } = basics
---


<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>
    <meta name="description" content={summary} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preload" as="image" href={image} />

    <meta property="og:url" content={url} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={summary} />
    <meta property="og:image" content="" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta property="twitter:domain" content={url.split("//")[1] ?? ''} />
    <meta property="twitter:url" content={url} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={summary} />
    <meta name="twitter:image" content="" />

    <!-- Google Fonts: JetBrains Mono + Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Anti-flash-of-wrong-theme: runs before first paint -->
    <script is:inline>
      (function() {
        var theme = localStorage.getItem('theme') ||
          (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>

    <ViewTransitions />
  </head>
  <body>
    <!-- Skip link: first focusable element -->
    <a href="#main-content" class="sr-only skip-link">
      Saltar al contenido principal
    </a>
    <slot />
  </body>
</html>

<style is:global>
  /* ── Design Tokens: Dark Theme (default) ── */
  :root {
    /* Colors */
    --color-bg-primary: #0a0a0f;
    --color-bg-secondary: #111118;
    --color-bg-tertiary: #1a1a2e;
    --color-accent: #34d399;
    --color-accent-muted: rgba(52, 211, 153, 0.12);
    --color-text-primary: #e2e8f0;
    --color-text-secondary: #94a3b8;
    --color-text-muted: #64748b;
    --color-border: rgba(52, 211, 153, 0.15);
    --color-border-hover: rgba(52, 211, 153, 0.3);

    /* Typography */
    --font-mono: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace;
    --font-sans: 'Inter', system-ui, -apple-system, sans-serif;
    --font-size-xs: 0.75rem;
    --font-size-sm: 0.875rem;
    --font-size-base: 1rem;
    --font-size-lg: 1.125rem;
    --font-size-xl: 1.25rem;
    --font-size-2xl: 1.5rem;
    --font-size-3xl: 2rem;

    /* Spacing (4px base scale) */
    --space-1: 0.25rem;
    --space-2: 0.5rem;
    --space-3: 0.75rem;
    --space-4: 1rem;
    --space-6: 1.5rem;
    --space-8: 2rem;
    --space-12: 3rem;
    --space-16: 4rem;

    /* Borders */
    --radius-sm: 4px;
    --radius-md: 8px;
    --radius-lg: 12px;

    /* Shadows */
    --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.5);
    --shadow-md: 0 4px 6px rgba(0, 0, 0, 0.5);
    --shadow-lg: 0 10px 15px rgba(0, 0, 0, 0.5);

    /* Transitions */
    --transition-fast: 150ms ease;
    --transition-base: 250ms ease;
    --transition-slow: 350ms ease;

    /* Layout */
    --max-width: 900px;
    --nav-height: 56px;
  }

  /* ── Light Theme Override ── */
  [data-theme="light"] {
    --color-bg-primary: #f8fafc;
    --color-bg-secondary: #ffffff;
    --color-bg-tertiary: #f1f5f9;
    --color-accent: #059669;
    --color-accent-muted: rgba(5, 150, 105, 0.1);
    --color-text-primary: #0f172a;
    --color-text-secondary: #475569;
    --color-text-muted: #475569;
    --color-border: rgba(5, 150, 105, 0.2);
    --color-border-hover: rgba(5, 150, 105, 0.4);
  }

  /* ── Global Resets ── */
  html {
    font-family: var(--font-sans);
    background: var(--color-bg-primary);
    color: var(--color-text-primary);
    letter-spacing: -0.025rem;
    scroll-behavior: smooth;
    transition: background var(--transition-base), color var(--transition-base);
  }

  body,
  figure {
    margin: 0;
    padding: 0;
  }

  a {
    text-decoration: none;
    color: var(--color-accent);
    transition: color var(--transition-fast);
  }

  a:hover {
    color: var(--color-border-hover);
  }

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  h1,
  h2,
  h3,
  h4 {
    margin: 0;
    font-family: var(--font-mono);
    color: var(--color-text-primary);
  }

  p {
    color: var(--color-text-secondary);
    font-size: var(--font-size-sm);
    line-height: 1.5;
    margin: 0;
    text-wrap: pretty;
  }

  .print {
    display: none !important;
  }

  /* ── Screen Reader Only (visually hidden but accessible) ── */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  /* ── Skip Link (visible on focus) ── */
  .skip-link {
    z-index: 9999;
  }

  .skip-link:focus {
    position: fixed;
    top: var(--space-2);
    left: 50%;
    transform: translateX(-50%);
    width: auto;
    height: auto;
    padding: var(--space-2) var(--space-4);
    margin: 0;
    overflow: visible;
    clip: auto;
    white-space: normal;
    background: var(--color-accent);
    color: var(--color-bg-primary);
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    font-weight: 600;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
  }

  @media print {
    .no-print {
      display: none !important;
    }

    .print {
      display: block !important;
    }

    astro-dev-toolbar {
      display: none !important;
    }

    article {
      break-inside: avoid;
    }
  }
</style>
