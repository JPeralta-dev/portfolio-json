---
import type { Basics } from "@/cv"
import Section from "@/components/Section.astro"
import TerminalText from "@/components/TerminalText.astro"
import NetworkBackground from "@/components/NetworkBackground.astro"
import ThemeToggle from "@/components/ThemeToggle.astro"
import Mail from "@/icons/Mail.astro"
import Phone from "@/icons/Phone.astro"
import LinkedIn from "@/icons/LinkedIn.astro"
import GitHub from "@/icons/GitHub.astro"
import WorldMap from "@/icons/WorldMap.astro"
import Resume2 from "@/icons/Resume2.astro"
import type { SocialIcon } from "@/types"

interface Props {
  basics: Basics
}

const { basics } = Astro.props
const { name, label, image, location, profiles, phone, email} = basics
const { city, region } = location

const SOCIAL_ICONS: SocialIcon = {
  GitHub,
  LinkedIn
}



const linkedInfo = profiles.find(({ network }) => network === "LinkedIn")
const linkedUrl = linkedInfo?.url

const printInfo = [email, phone, linkedUrl].filter(Boolean).join(" • ")
---

<Section transitionName="section-hero">
  <div class="hero-wrapper">
    <NetworkBackground />
    <div class="theme-toggle-position">
      <ThemeToggle />
    </div>
    <div class="container">
      <div class="info">
        <h1 class="name-heading">
          <TerminalText text={name} />
        </h1>
        <h2 class="label">{label}</h2>
        <span class="location">
          <WorldMap />
          {city}, {region}
        </span>
        <footer class="print">
          {printInfo}
        </footer>
        <footer class="no-print social-links">
          {
            email && (
              <a
                href={`mailto:${email}`}
                title={`Enviar un correo electrónico a ${name} al correo ${email}`}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`Enviar correo a ${name}`}
              >
                <Mail />
              </a>
            )
          }
          {
            phone && (
              <a
                href={`tel:${phone}`}
                title={`Llamar por teléfono a ${name} al número ${phone}`}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`Llamar a ${name}`}
              >
                <Phone />
              </a>
            )
          }
          {
            name && (
              <a 
              href= "../../../public/CV Back_Junior.pdf"
              title={`Descargar el curriculum de ${name}`}
              download="CV Back_Junior.pdf"
              rel="noopener noreferrer"
              aria-label={`Descargar CV de ${name}`}
              >
                <Resume2 />
              </a>
            )
          }
          {
            profiles.map(({ network, url }) => {
              const Icon = SOCIAL_ICONS[network]

              return (
                <a
                  href={url}
                  title={`Visitar el perfil de ${name} en ${network}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`Perfil de ${name} en ${network}`}
                >
                  <Icon />
                </a>
              )
            })
          }
        </footer>
      </div>
      <figure class="profile-figure">
        <img src={image} alt={name} loading="eager" />
      </figure>
    </div>
  </div>
</Section>

<style>
  .hero-wrapper {
    position: relative;
    overflow: hidden;
  }

  .container {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    padding: var(--space-8) 0;
  }

  .info {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-right: var(--space-8);
    flex: 1;
  }

  .name-heading {
    margin: 0;
    font-size: inherit;
    font-weight: inherit;
    line-height: inherit;
  }

  .label {
    color: var(--color-text-secondary);
    font-weight: 500;
    font-size: var(--font-size-lg);
    text-wrap: balance;
    font-family: var(--font-sans);
  }

  .location {
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--font-size-sm);
    letter-spacing: -0.025rem;
  }

  .profile-figure {
    flex-shrink: 0;
  }

  .profile-figure img {
    aspect-ratio: 1 / 1;
    object-fit: cover;
    width: 140px;
    border-radius: var(--radius-lg);
    border: 2px solid var(--color-border);
    box-shadow: var(--shadow-md);
    transition: border-color var(--transition-base), box-shadow var(--transition-base);
  }

  .profile-figure img:hover {
    border-color: var(--color-accent);
    box-shadow: 0 0 12px var(--color-accent-muted);
  }

  .hero-actions {
    display: none;
  }

  .theme-toggle-position {
    position: absolute;
    top: var(--space-2);
    right: var(--space-2);
    z-index: 2;
  }

  .social-links {
    color: var(--color-text-secondary);
    font-size: var(--font-size-sm);
    display: flex;
    gap: var(--space-2);
    margin-top: var(--space-2);
  }

  .social-links a {
    color: var(--color-text-muted);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-border);
    padding: var(--space-1);
    height: 36px;
    width: 36px;
    border-radius: var(--radius-md);
    background: var(--color-bg-secondary);
    transition: all var(--transition-base);
  }

  .social-links a:hover {
    border-color: var(--color-border-hover);
    background: var(--color-accent-muted);
    color: var(--color-accent);
    transform: translateY(-2px);
  }

  .social-links a[href*="linkedin.com"]:hover {
    background: #0077b5;
    color: white;
    border-color: #0077b5;
  }

  .social-links a[href*="mailto:"]:hover {
    background: #d14836;
    color: white;
    border-color: #d14836;
  }

  .social-links a[href*="CV Back_Junior.pdf"]:hover {
    background: #4faadc;
    color: white;
    border-color: #4faadc;
  }

  .social-links a[href*="github.com"]:hover {
    background: #333;
    color: white;
    border-color: #333;
  }

  .social-links a[href*="tel:"]:hover {
    background: #34b233;
    color: white;
    border-color: #34b233;
  }

  .social-links a:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  @media (width <= 700px) {
    .container {
      flex-direction: column-reverse;
      text-align: center;
      padding: var(--space-6) 0;
    }

    .info {
      justify-content: center;
      align-items: center;
      padding-right: 0;
    }

    .location {
      justify-content: center;
    }

    .social-links {
      justify-content: center;
    }

    .theme-toggle-position {
      top: var(--space-1);
      right: var(--space-1);
    }

    .profile-figure {
      display: flex;
      justify-content: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .social-links a,
    .profile-figure img {
      transition-duration: 0ms !important;
    }

    .social-links a:hover {
      transform: none !important;
    }
  }
</style>
