---
import Section from "../Section.astro"
import HTML from "@/icons/html.astro"
import CSS from "@/icons/css.astro"
import JavaScript from "@/icons/javascript.astro"
import TypeScript from "@/icons/type.astro"
import React from "@/icons/react.astro"
import Node from "@/icons/node.astro"
import MySQL from "@/icons/sql.astro"
import Git from "@/icons/git.astro"
import GitHub from "@/icons/GitHub.astro"
import Tailwind from "@/icons/tailwind.astro"
import Next from "@/icons/next.astro"
import { skills } from "@cv"
import Swift from "@/icons/swift.astro"
import SwiftUI from "@/icons/swiftui.astro"
import Kotlin from "@/icons/kotlin.astro"
import Flutter from "@/icons/flutter.astro"

const SKILLS_ICONS: Record<string, any> = {
  HTML,
  CSS,
  JavaScript,
  TypeScript,
  React,
  Node,
  MySQL,
  Git,
  GitHub,
  Next,
  Tailwind,
  Swift,
  SwiftUI,
  Kotlin,
  Flutter,
}

// Categorize skills by their primary keyword
function categorizeSkills(skillsList: typeof skills) {
  const categories: Record<string, typeof skills> = {}
  
  for (const skill of skillsList) {
    const keywords = skill.keywords || []
    // Determine category from keywords
    let category = "Otros"
    if (keywords.includes("Frontend") || keywords.includes("Desarrollo Web")) {
      category = "Frontend"
    } else if (keywords.includes("Backend") || keywords.includes("Servidor")) {
      category = "Backend"
    } else if (keywords.includes("Bases de Datos") || keywords.includes("SQL")) {
      category = "Bases de Datos"
    } else if (keywords.includes("Control de Versiones") || keywords.includes("Colaboración")) {
      category = "Herramientas"
    } else if (keywords.includes("CSS Framework") || keywords.includes("React Framework")) {
      category = "Frameworks"
    } else if (keywords.includes("UI")) {
      category = "Frontend"
    } else if (keywords.includes("JavaScript Superset")) {
      category = "Backend"
    }
    
    if (!categories[category]) {
      categories[category] = []
    }
    categories[category].push(skill)
  }
  
  return categories
}

const categorizedSkills = categorizeSkills(skills)

// Maintain a consistent display order
const categoryOrder = ["Frontend", "Backend", "Frameworks", "Bases de Datos", "Herramientas"]
const orderedCategories = categoryOrder.filter(cat => categorizedSkills[cat])
// Add any remaining categories not in the order list
for (const cat of Object.keys(categorizedSkills)) {
  if (!orderedCategories.includes(cat)) {
    orderedCategories.push(cat)
  }
}
---

<Section title="Habilidades" transitionName="section-skills">
  <div class="skills-grid">
    {orderedCategories.map((category) => (
      <div class="skill-category">
        <h3 class="category-title">{category}</h3>
        <ul class="skill-pills">
          {
            categorizedSkills[category].map(({ name }) => {
              const iconName = name === "Next.js" ? "Next" : name
              const Icon = SKILLS_ICONS[iconName]

              return (
                <li class="pill">
                  {Icon && <span class="pill-icon"><Icon /></span>}
                  <span>{name}</span>
                </li>
              )
            })
          }
        </ul>
      </div>
    ))}
  </div>
</Section>

<style>
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-4);
  }

  .skill-category {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .category-title {
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--color-accent);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding-bottom: var(--space-1);
    border-bottom: 1px solid var(--color-border);
  }

  .skill-pills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .pill {
    align-items: center;
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text-primary);
    display: inline-flex;
    font-size: var(--font-size-xs);
    font-weight: 500;
    gap: var(--space-1);
    padding: var(--space-1) var(--space-2);
    transition: border-color var(--transition-fast), background var(--transition-fast), transform var(--transition-fast);
  }

  .pill:hover {
    border-color: var(--color-border-hover);
    background: var(--color-accent-muted);
    transform: translateY(-1px);
  }

  .pill-icon {
    display: inline-flex;
    align-items: center;
    color: var(--color-text-muted);
  }

  @media (width <= 700px) {
    .skills-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
