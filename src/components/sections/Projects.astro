---
import GitHub from "@/icons/GitHub.astro"
import Section from "../Section.astro"

import { projects } from "@cv"
---

<Section title="Proyectos" transitionName="section-projects">
  <div class="bento-grid">
    {
      projects.map(
        ({ url, description, highlights, name, isActive, github, images }, idx) => {
          const isFeatured = idx === 0
          return (
            <article class={`project-card ${isFeatured ? 'featured' : ''}`}>
              <header>
                <h3>
                  <a href={url} target="_blank" title={`Ver el proyecto ${name}`}>
                    {name}
                  </a>
                  {isActive && <span class="active-dot" aria-label="Proyecto activo">•</span>}
                  {github && (
                    <a
                      class="github-code-link"
                      href={github}
                      target="_blank"
                      title={`Ver código fuente del proyecto ${name}`}
                      aria-label={`Código fuente de ${name}`}
                    >
                      <GitHub />
                    </a>
                  )}
                </h3>
                <p>{description}</p>
              </header>
              {images && images.length > 0 && (
                <figure class="project-images">
                  {images.map((img) => {
                    const fixedSrc = img.replace('/public/projects/', '/projects/')
                    return <img src={fixedSrc} alt={`Imagen del proyecto ${name}`} loading="lazy" />
                  })}
                </figure>
              )}
              {highlights && highlights.length > 0 && (
                <footer class="tech-badges">
                  {highlights.map((highlight) => (
                    <span class="badge">{highlight}</span>
                  ))}
                </footer>
              )}
            </article>
          )
        }
      )
    }
  </div>
</Section>

<style>
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-4);
  }

  .project-card {
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-4);
    background: var(--color-bg-secondary);
    transition: transform var(--transition-base), border-color var(--transition-base), box-shadow var(--transition-base);
  }

  .project-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-border-hover);
    box-shadow: var(--shadow-lg);
  }

  .project-card.featured {
    grid-column: span 2;
  }

  .project-card header {
    flex: 1;
  }

  .project-card h3 {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-2);
    font-size: var(--font-size-lg);
  }

  .project-card h3 a {
    color: var(--color-text-primary);
    transition: color var(--transition-fast);
  }

  .project-card h3 a:hover {
    color: var(--color-accent);
  }

  .active-dot {
    color: var(--color-accent);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .github-code-link {
    margin-left: auto;
    color: var(--color-text-muted);
    display: inline-flex;
    align-items: center;
    transition: color var(--transition-fast);
  }

  .github-code-link:hover {
    color: var(--color-text-primary);
  }

  .project-card p {
    font-size: var(--font-size-sm);
    line-height: 1.6;
    color: var(--color-text-secondary);
  }

  .project-images {
    display: flex;
    gap: var(--space-2);
    overflow-x: auto;
    margin: 0;
  }

  .project-images img {
    aspect-ratio: 16 / 10;
    object-fit: cover;
    height: 120px;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    flex-shrink: 0;
  }

  .tech-badges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .badge {
    border-radius: var(--radius-sm);
    background: var(--color-accent-muted);
    color: var(--color-accent);
    font-size: var(--font-size-xs);
    font-weight: 500;
    font-family: var(--font-mono);
    padding: var(--space-1) var(--space-2);
    transition: background var(--transition-fast), transform var(--transition-fast);
  }

  .badge:hover {
    background: var(--color-border-hover);
    transform: scale(1.05);
  }

  @media (width <= 700px) {
    .bento-grid {
      grid-template-columns: 1fr;
    }

    .project-card.featured {
      grid-column: span 1;
    }

    .project-card {
      border: none;
      box-shadow: var(--shadow-sm);
      padding: var(--space-3) 0;
    }

    .project-images img {
      height: 100px;
    }
  }

  @media print {
    .active-dot {
      animation: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .active-dot {
      animation: none !important;
    }

    .project-card,
    .badge {
      transition-duration: 0ms !important;
    }
  }
</style>
