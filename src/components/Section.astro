---
interface Props {
  title?: string
  transitionName?: string
}

const { title, transitionName } = Astro.props
const sectionId = `section-${title?.toLowerCase().replace(/\s+/g, '-') ?? Astro.props.transitionName ?? 'default'}`
---

<section
  style={transitionName ? `view-transition-name: ${transitionName}` : undefined}
  {...(title ? { 'aria-labelledby': `${sectionId}-title` } : {})}
>
  {title && <h2 id={`${sectionId}-title`}>{title}</h2>}
  <slot />
</section>

<script>
  // se ejecuta en el cliente <----
</script>

<style>
  section {
    max-width: var(--max-width);
    margin: 0 auto var(--space-16);
  }

  section:last-of-type {
    margin-bottom: var(--space-8);
  }

  h2 {
    margin-bottom: var(--space-4);
    font-weight: 700;
    line-height: 1.5;
    font-size: var(--font-size-2xl);
    font-family: var(--font-mono);
    color: var(--color-text-primary);
  }

  @media (width <= 700px) {
    section {
      margin-bottom: var(--space-10, 38px);
    }
  }
</style>
